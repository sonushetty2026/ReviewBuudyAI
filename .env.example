# Google Places API (for review linking)
NEXT_PUBLIC_GOOGLE_PLACE_ID=your_google_place_id_here

# Business Configuration
NEXT_PUBLIC_BUSINESS_NAME="Your Business Name"
NEXT_PUBLIC_BUSINESS_OWNER_EMAIL=owner@example.com

# Alert webhook (for negative feedback owner alerts)
OWNER_ALERT_WEBHOOK_URL=https://hooks.example.com/alert

# Reward configuration
REWARD_CODE_PREFIX=RB
REWARD_DISCOUNT_PERCENT=10
